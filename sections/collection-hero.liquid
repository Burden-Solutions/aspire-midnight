{% comment %}
  Section: collection-hero
  Page header for collection pages — shows collection title, description, and product count.
{% endcomment %}

<div class="collection-hero">
  <div class="collection-hero__inner">
    <div class="collection-hero__eyebrow">
      <a href="{{ routes.root_url }}" class="collection-hero__breadcrumb">Home</a>
      <span class="collection-hero__breadcrumb-sep" aria-hidden="true">/</span>
      <span class="collection-hero__breadcrumb-current">{{ collection.title }}</span>
    </div>

    <h1 class="pf collection-hero__title">
      <span class="collection-hero__line1">{{ collection.title | upcase | split: ' ' | first }}</span>
      <span class="collection-hero__line2 collection-hero__line2--italic">
        {{ collection.title | split: ' ' | slice: 1, 10 | join: ' ' }}
      </span>
    </h1>

    {%- if collection.description != blank -%}
      <p class="collection-hero__desc">{{ collection.description }}</p>
    {%- endif -%}

    <div class="collection-hero__meta">
      <span class="collection-hero__count">
        {{ collection.products_count }}
        {{ collection.products_count | pluralize: 'product', 'products' }}
      </span>
    </div>
  </div>

  {%- if collection.image -%}
    <div class="collection-hero__media">
      {{ collection.image | image_url: width: 1400 | image_tag:
           class: 'collection-hero__img',
           alt: collection.image.alt | default: collection.title,
           loading: 'eager',
           fetchpriority: 'high' }}
      <div class="collection-hero__media-tint" aria-hidden="true"></div>
    </div>
  {%- endif -%}
</div>

<style>
.collection-hero {
  position: relative;
  min-height: 340px;
  display: flex;
  align-items: flex-end;
  border-bottom: 1px solid var(--border);
  overflow: hidden;
  background: var(--bg2);
}
.collection-hero__media {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.collection-hero__img { width: 100%; height: 100%; object-fit: cover; }
.collection-hero__media-tint {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(10,9,8,0.92) 0%, rgba(10,9,8,0.5) 60%, rgba(10,9,8,0.2) 100%);
}
.collection-hero__inner {
  position: relative;
  z-index: 1;
  padding: 60px;
  max-width: 640px;
}
.collection-hero__eyebrow {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 28px;
}
.collection-hero__breadcrumb {
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--w40);
  transition: color 0.2s;
}
.collection-hero__breadcrumb:hover { color: var(--orange); }
.collection-hero__breadcrumb-sep { color: var(--w20); font-size: 11px; }
.collection-hero__breadcrumb-current {
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--orange);
}
.collection-hero__title {
  line-height: 0.92;
  font-weight: 900;
  margin: 0 0 24px;
}
.collection-hero__line1 { display: block; font-size: clamp(48px, 6vw, 88px); color: var(--white); }
.collection-hero__line2 { display: block; font-size: clamp(48px, 6vw, 88px); color: var(--w20); margin-top: -2px; }
.collection-hero__line2--italic { font-style: italic; font-weight: 400; color: var(--w40); }
.collection-hero__desc {
  color: var(--w60);
  font-size: 14px;
  line-height: 1.8;
  font-weight: 300;
  margin-bottom: 24px;
  max-width: 420px;
}
.collection-hero__meta { display: flex; align-items: center; gap: 20px; }
.collection-hero__count {
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--w40);
  border: 1px solid var(--border);
  padding: 6px 14px;
}

@media (max-width: 768px) {
  .collection-hero__inner { padding: 40px 32px; }
}
</style>

{% schema %}
{
  "name": "Collection Hero",
  "tag": "div",
  "settings": [],
  "presets": [
    { "name": "Collection Hero" }
  ]
}
{% endschema %}
