{% comment %}
  Section: footer
  Site-wide footer with brand column, nav columns, inline newsletter, and legal bar.
{% endcomment %}

<footer class="site-footer" role="contentinfo">
  <div class="footer-main">
    {%- comment -%} Brand column {%- endcomment -%}
    <div>
      <div class="footer-brand__logo pf">
        {{ section.settings.logo_text | default: 'ASPIRE' }}<span>.</span>
      </div>
      <p class="footer-brand__desc">
        {{ section.settings.tagline | default: 'Premium tapware and fixtures for Australian homes. Quality-first, service-always.' }}
      </p>
      <div class="footer-social">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" class="footer-social__link" aria-label="Instagram">IG</a>
        {%- endif -%}
        {%- if section.settings.pinterest_url != blank -%}
          <a href="{{ section.settings.pinterest_url }}" class="footer-social__link" aria-label="Pinterest">PI</a>
        {%- endif -%}
        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" class="footer-social__link" aria-label="Facebook">FB</a>
        {%- endif -%}
        {%- if section.settings.youtube_url != blank -%}
          <a href="{{ section.settings.youtube_url }}" class="footer-social__link" aria-label="YouTube">YT</a>
        {%- endif -%}
        {%- comment -%} Fallback placeholders in editor {%- endcomment -%}
        {%- if section.settings.instagram_url == blank and section.settings.facebook_url == blank -%}
          {%- for handle in 'IG,PI,FB,YT' | split: ',' -%}
            <a href="#" class="footer-social__link" aria-label="{{ handle }}">{{ handle }}</a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Nav columns (menus) {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
        <div {{ block.shopify_attributes }}>
          <div class="footer-col__title">{{ block.settings.heading }}</div>
          <ul class="footer-col__list">
            {%- for link in linklists[block.settings.menu].links -%}
              <li><a href="{{ link.url }}" class="footer-col__link">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Footer newsletter {%- endcomment -%}
    <div class="footer-newsletter">
      <div class="footer-col__title">{{ section.settings.newsletter_heading | default: 'Newsletter' }}</div>
      <p class="footer-newsletter__desc">
        {{ section.settings.newsletter_desc | default: 'New arrivals and exclusive offers.' }}
      </p>
      {%- form 'customer', class: 'newsletter-form footer-newsletter' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          type="email"
          name="contact[email]"
          class="newsletter-form__input"
          placeholder="{{ section.settings.newsletter_placeholder | default: 'Email address' }}"
          autocomplete="email"
          required
        >
        <button type="submit" class="btn btn--primary btn--block btn--sm" style="margin-top:0">
          {{ section.settings.newsletter_btn | default: 'Subscribe' }}
        </button>
      {%- endform -%}
    </div>
  </div>

  {%- comment -%} Legal bar {%- endcomment -%}
  <div class="footer-bottom">
    <span>{{ section.settings.copyright | default: '© 2026 Aspire Bathrooms Pty Ltd. All rights reserved. All prices in AUD.' }}</span>
    <div class="footer-legal">
      {%- if linklists[section.settings.legal_menu].links.size > 0 -%}
        {%- for link in linklists[section.settings.legal_menu].links -%}
          <a href="{{ link.url }}" class="footer-legal__link">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="#" class="footer-legal__link">Privacy Policy</a>
        <a href="#" class="footer-legal__link">Terms &amp; Conditions</a>
        <a href="#" class="footer-legal__link">Accessibility</a>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "header",    "content": "Brand" },
    { "type": "text",      "id": "logo_text",            "label": "Logo text",                "default": "ASPIRE" },
    { "type": "textarea",  "id": "tagline",              "label": "Brand tagline",             "default": "Premium tapware and fixtures for Australian homes. Quality-first, service-always." },
    { "type": "header",    "content": "Social links" },
    { "type": "url",       "id": "instagram_url",        "label": "Instagram URL" },
    { "type": "url",       "id": "pinterest_url",        "label": "Pinterest URL" },
    { "type": "url",       "id": "facebook_url",         "label": "Facebook URL" },
    { "type": "url",       "id": "youtube_url",          "label": "YouTube URL" },
    { "type": "header",    "content": "Newsletter" },
    { "type": "text",      "id": "newsletter_heading",   "label": "Heading",                  "default": "Newsletter" },
    { "type": "text",      "id": "newsletter_desc",      "label": "Description",              "default": "New arrivals and exclusive offers." },
    { "type": "text",      "id": "newsletter_placeholder","label": "Input placeholder",       "default": "Email address" },
    { "type": "text",      "id": "newsletter_btn",       "label": "Button text",              "default": "Subscribe" },
    { "type": "header",    "content": "Legal bar" },
    { "type": "text",      "id": "copyright",            "label": "Copyright text",           "default": "© 2026 Aspire Bathrooms Pty Ltd. All rights reserved. All prices in AUD." },
    { "type": "link_list", "id": "legal_menu",           "label": "Legal links menu",         "default": "footer" }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Navigation column",
      "settings": [
        { "type": "text",      "id": "heading", "label": "Heading",  "default": "Shop" },
        { "type": "link_list", "id": "menu",    "label": "Menu",     "default": "main-menu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Shop",    "menu": "main-menu"   } },
        { "type": "link_list", "settings": { "heading": "Company", "menu": "footer"      } },
        { "type": "link_list", "settings": { "heading": "Support", "menu": "footer"      } }
      ]
    }
  ]
}
{% endschema %}
