{% comment %}
  Section: header
  Sticky navigation bar with logo, nav links, search, wishlist, and cart.
{% endcomment %}

<header class="site-header" role="banner">
  <a href="{{ routes.root_url }}" class="site-header__logo pf">
    {{ section.settings.logo_text | default: 'ASPIRE' }}<span>.</span>
  </a>

  <nav class="site-header__nav" role="navigation" aria-label="Main navigation">
    {%- for link in linklists[section.settings.menu].links -%}
      <a
        href="{{ link.url }}"
        class="nav-link{% if link.active %} active{% endif %}"
      >
        {{ link.title }}
      </a>
    {%- else -%}
      {%- assign default_links = 'Bathroom,Kitchen,Laundry,Outdoor,Finishes,Trade' | split: ',' -%}
      {%- for label in default_links -%}
        <a href="#" class="nav-link">{{ label }}</a>
      {%- endfor -%}
    {%- endfor -%}
  </nav>

  <div class="site-header__icons">
    <button class="icon-btn" aria-label="Search" onclick="window.location='{{ routes.search_url }}'">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="1.5" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
    </button>

    {%- if section.settings.show_wishlist -%}
    <button class="icon-btn" aria-label="Wishlist">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="1.5" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>
    {%- endif -%}

    <a href="{{ routes.cart_url }}" class="btn btn--outline-orange" aria-label="Cart">
      Cart
      <span class="cart-count">{{ cart.item_count }}</span>
    </a>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "ASPIRE"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist icon",
      "default": true
    }
  ]
}
{% endschema %}
